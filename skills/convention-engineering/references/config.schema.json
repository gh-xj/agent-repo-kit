{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/convention-engineering.schema.json",
  "title": "Convention Engineering Contract",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "contract_version",
    "mode",
    "profiles",
    "docs_root",
    "ownership_policy",
    "mirror_policy",
    "evaluation_inputs",
    "chunk_plan"
  ],
  "properties": {
    "contract_version": {
      "type": "integer",
      "const": 1
    },
    "mode": {
      "type": "string",
      "enum": ["tracked", "overlay"]
    },
    "profiles": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "docs_root": {
      "type": "string",
      "enum": ["docs", ".docs"]
    },
    "ownership_policy": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "portable_skill_authoring_owner",
        "domain_knowledge_owner",
        "repo_local_skills"
      ],
      "properties": {
        "portable_skill_authoring_owner": { "type": "string", "minLength": 1 },
        "domain_knowledge_owner": { "type": "string", "minLength": 1 },
        "repo_local_skills": {
          "type": "object",
          "additionalProperties": true,
          "required": [
            "allowed",
            "placement_roots",
            "authoring_owner",
            "requires_justification"
          ],
          "properties": {
            "allowed": { "type": "boolean" },
            "placement_roots": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string", "minLength": 1 }
            },
            "authoring_owner": { "type": "string", "minLength": 1 },
            "requires_justification": { "type": "boolean" }
          }
        }
      }
    },
    "mirror_policy": {
      "type": "object",
      "additionalProperties": true,
      "required": ["mode", "files"],
      "properties": {
        "mode": { "type": "string", "minLength": 1 },
        "files": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "evaluation_inputs": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "repo_risk": { "type": "string", "minLength": 1 }
      }
    },
    "chunk_plan": {
      "type": "object",
      "additionalProperties": true,
      "required": ["enabled", "chunks"],
      "properties": {
        "enabled": { "type": "boolean" },
        "chunks": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "required": ["id", "scope", "completion_criteria", "depends_on"],
            "properties": {
              "id": {
                "type": "string",
                "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
              },
              "scope": { "type": "string", "minLength": 1 },
              "completion_criteria": {
                "type": "array",
                "minItems": 1,
                "items": { "type": "string", "minLength": 1 }
              },
              "depends_on": {
                "type": "array",
                "items": {
                  "type": "string",
                  "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
                }
              }
            }
          }
        }
      }
    },
    "required_files": {
      "default": ["Taskfile.yml"],
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "taskfile_checks": {
      "default": {},
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": { "type": "string", "minLength": 1 }
      }
    },
    "canonical_pointer_mode": {
      "default": "all",
      "type": "string",
      "enum": ["all", "any"]
    },
    "canonical_pointers": {
      "default": [],
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["name", "file", "text"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "file": { "type": "string", "minLength": 1 },
          "text": { "type": "string", "minLength": 1 }
        }
      }
    },
    "content_checks": {
      "default": [],
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["name", "file", "required_markers"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "file": { "type": "string", "minLength": 1 },
          "required_markers": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "git_exclude_checks": {
      "default": [],
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["name", "file", "required_patterns"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "file": { "type": "string", "minLength": 1 },
          "required_patterns": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "invariant_contract": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "required": {
          "type": "boolean",
          "default": false
        },
        "file": {
          "type": "string",
          "minLength": 1,
          "default": ".claude/architecture/invariants.yaml"
        },
        "required_fields": {
          "type": "array",
          "default": [
            "id",
            "statement",
            "status",
            "evidence",
            "enforceability",
            "owner",
            "last_verified"
          ],
          "items": { "type": "string", "minLength": 1 }
        },
        "exception_fields": {
          "type": "array",
          "default": [
            "exception_reason",
            "exception_owner",
            "exception_expires"
          ],
          "items": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
